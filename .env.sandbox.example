# Vite picks this file up when running with `--mode sandbox`:
#   npm run dev:sandbox     -> dev server on :5173 against sandbox backend
#   npm run build:sandbox   -> production-mode bundle pointed at sandbox
#
# Same bundle as production but every transaction signs via v3
# (preview -> passkey -> submit-prepared) and signup enrols a passkey.
# Prod builds (npm run build) don't see this file at all.

# Sandbox project API key. Get one from the Rift dashboard (use your
# sandbox project, NOT prod). The widget+backend allow-lists also need
# to include your dev origin (http://localhost:5173) and any deployed
# sandbox host.
VITE_SDK_API_KEY=

# Switch SDK + raw fetch base URL to the sandbox backend.
VITE_RIFT_ENVIRONMENT=sandbox
VITE_RIFT_API_BASE=https://sandbox.riftfi.com

# Turn ON non-custodial mode. Every signup/signin enrols (or migrates
# to) a v3 envelope; every on-chain action signs via the two-phase
# preview/submit-prepared flow with an authProof bound to the user_op_hash.
VITE_NON_CUSTODIAL=true

# WebAuthn Relying Party id. eTLD+1 of where this app runs.
#   - localhost dev:                 localhost
#   - sandbox.app.riftfi.com:        riftfi.com
#   - app.sandbox.riftfi.com:        riftfi.com
VITE_PASSKEY_RP_ID=localhost
VITE_PASSKEY_RP_NAME=Rift Sandbox
